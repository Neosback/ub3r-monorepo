# Copy this file to .env. Never commit real credentials.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=dodian
DATABASE_TABLE_PREFIX=
DATABASE_USERNAME=dodian
DATABASE_PASSWORD=
DATABASE_INITIALIZE=false

CLIENT_VERSION=12
RSA_MODULUS=replace_with_your_rsa_modulus
RSA_EXPONENT=replace_with_your_rsa_private_exponent

# Leave the token blank to disable Discord. The channel's guild is inferred.
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
# Optional overrides; the general channel is reused for staff alerts by default.
DISCORD_GUILD_ID=
DISCORD_STAFF_ALERT_CHANNEL_ID=
